# Nginx reverse-proxy config for Keep Fit.
# Drop into /etc/nginx/sites-available/keep-fit, then:
#   sudo ln -s /etc/nginx/sites-available/keep-fit /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
# Then add TLS:
#   sudo certbot --nginx -d keepfit.example.com

server {
    listen 80;
    listen [::]:80;
    server_name keepfit.example.com;       # <-- change to your domain

    # Cache the immutable Next.js assets aggressively at the edge
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # PWA service worker — never cache at the proxy
    location = /sw.js {
        proxy_pass http://127.0.0.1:3000;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # Go backend API — proxied to the keep-fit-api process on 8080.
    # No caching: every API response is per-user and dynamic.
    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
        add_header Cache-Control "no-store";
    }

    # Manifest
    location = /manifest.webmanifest {
        proxy_pass http://127.0.0.1:3000;
        add_header Cache-Control "public, max-age=3600";
    }

    # Everything else — pass through
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Optional: gzip the responses we proxy
    gzip on;
    gzip_types
        application/javascript
        application/json
        application/manifest+json
        application/xml
        image/svg+xml
        text/css
        text/plain;
    gzip_min_length 1024;
}
